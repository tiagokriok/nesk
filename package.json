{
  "name": "Nesk",
  "version": "1.1.0",
  "main": "dist-electron/main.js",
  "description": "Electron-based Pomodoro Timer using Vue + Vite + TypeScript",
  "author": {
    "name": "Tiago Carioca",
    "email": "tiagoacarioca@gmail.com",
    "url": "https://tiagokriok.dev/"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder"
  },
  "engines": {
    "node": "^14.18.0 || >=16.0.0"
  },
  "dependencies": {
    "@heroicons/vue": "^2.0.13",
    "@vueuse/electron": "^9.6.0",
    "electron-store": "^8.1.0",
    "json-schema-typed": "^8.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^3.1.2",
    "autoprefixer": "^10.4.13",
    "electron": "^22.0.0",
    "electron-builder": "^23.3.3",
    "postcss": "^8.4.19",
    "tailwindcss": "^3.2.4",
    "typescript": "^4.8.4",
    "vite": "^3.2.2",
    "vite-plugin-electron": "^0.10.4",
    "vite-plugin-electron-renderer": "^0.11.3",
    "vue": "^3.2.40",
    "vue-tsc": "^1.0.9"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344"
    }
  },
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue",
    "nesk"
  ]
}
